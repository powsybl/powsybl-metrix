#: ../../mapping.md:195
#: 3f4e3e558b8f4f8ea141ced9cd7b81ee
msgid "Generators and HVDC limits"
msgstr ""

#: ../../mapping.md:197
#: ffb86ce1d5964e2b9533a21032579bbc
msgid "When mapping a time series to a generator or a HVDC line, a time series value may break a threshold defined in the network case  (a max power or min power for instance). To handle this case we can choose to ignore the limit with either:"
msgstr ""

#: ../../mapping.md:199
#: f5cb7291a6cf4debb3713a8abab452f5
msgid "a global parameter : use `--ignore-limits` in the command line interface parameter"
msgstr ""

#: ../../mapping.md:200
#: a1129afa132b4aeba59ae0f19be9da9d
msgid "a per time series configuration : add `ignoreLimits { \"timeSeriesName\" }` for each wanted time series"
msgstr ""

#: ../../mapping.md:202
#: cda8c59258454cd3941f6473c213f077
msgid "If no option is set to ignore the limits, then if it happens, the program will exit with an exception. Otherwise it will log a warning message."
msgstr ""

